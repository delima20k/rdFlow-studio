# Servidor
PORT=3000
NODE_ENV=development
DB_PATH=./data/streaming.sqlite
FFMPEG_PATH=ffmpeg

# RTMP Server
RTMP_PORT=1935
RTMP_CHUNK_SIZE=60000
RTMP_GOP_CACHE=true
RTMP_PING=30
RTMP_PING_TIMEOUT=60

# HLS Configuration
HLS_PATH=./media/live
HLS_FRAGMENT=3
HLS_LIST_SIZE=3
HLS_CLEANUP=true

# API
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=*
